{
  "name": "nest-configured",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.0.0",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start:dev": "pnpm exec nest start --watch",
    "start": "node dist/main.js",
    "check": "pnpm exec prettier --check . && pnpm exec eslint . && pnpm exec tsc --noEmit",
    "test": "pnpm exec vitest",
    "test:e2e": "pnpm exec vitest --config vitest.config.e2e.ts --run",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "@fastify/helmet": "^13.0.2",
    "@nestjs/common": "^11.1.1",
    "@nestjs/core": "^11.1.1",
    "@nestjs/platform-fastify": "^11.1.1",
    "@nestjs/swagger": "^11.2.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.3.3",
    "nestjs-pino": "^4.1.0",
    "nestjs-zod": "^5.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@nestjs/cli": "^11.0.7",
    "@nestjs/testing": "^11.1.1",
    "@types/node": "^22.15.21",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.23.0",
    "eslint-plugin-prettier": "^5.2.6",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.0",
    "vitest": "^2.1.9"
  }
}
