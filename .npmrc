# Auth and registry settings only (pnpm 11+).
# All other pnpm settings live in pnpm-workspace.yaml.

# Explicitly pin auto-install-peers so the runtime config matches the
# value baked into pnpm-lock.yaml's settings: block. Without this, a
# container that doesn't ship pnpm-workspace.yaml may resolve a different
# default and fail with ERR_PNPM_LOCKFILE_CONFIG_MISMATCH.
auto-install-peers=true
