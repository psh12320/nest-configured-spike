# Auth and registry settings only (pnpm 11+).
# All other pnpm settings live in pnpm-workspace.yaml.

# In container builds pnpm-workspace.yaml is not always copied, so mirror
# the build-script approvals here. Without this, pnpm 11 fails with
# ERR_PNPM_IGNORED_BUILDS during `pnpm i --prod`.
strict-dep-builds=false
